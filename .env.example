# Copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed.
#
# Any ${VAR} referenced in config.yaml is read from here (or the real
# environment). Real environment variables take precedence over this file,
# which is what lets Docker and systemd inject secrets in production.

# Password for your Reolink camera or NVR account.
# Referenced in config.yaml as: password: "${REOLINK_PASSWORD}"
REOLINK_PASSWORD=your-camera-or-nvr-password

# If different cameras/NVRs use different accounts, add as many more as you
# need — any name starting with REOLINK_PASSWORD works, so use whatever's
# memorable (a number, a location, a device name...):
# REOLINK_PASSWORD_NVR=nvr-account-password
# REOLINK_PASSWORD_BACKYARD=another-password
# REOLINK_PASSWORD_2=yet-another-password
#
# Then reference the matching one per-camera in config.yaml:
#   password: "${REOLINK_PASSWORD_BACKYARD}"
# The Config page's password field lists whichever of these are currently
# set, so you can pick one from a dropdown instead of typing the name.
