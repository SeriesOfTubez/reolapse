# Copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed.
#
# Any ${VAR} referenced in config.yaml is read from here (or the real
# environment). Real environment variables take precedence over this file,
# which is what lets Docker and systemd inject secrets in production.

# Password for your Reolink camera or NVR account.
# Referenced in config.yaml as: password: "${REOLINK_PASSWORD}"
REOLINK_PASSWORD=your-camera-or-nvr-password

# If different cameras use different accounts, add more variables and
# reference them per-camera in config.yaml, e.g.:
# REOLINK_PASSWORD_BACKYARD=another-password
